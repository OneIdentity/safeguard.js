{
  "name": "@oneidentity/safeguard",
  "version": "8.0.3",
  "description": "One Identity Safeguard JavaScript/TypeScript SDK",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "browser": "./dist/browser.js",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./events": {
      "import": {
        "types": "./dist/events.d.ts",
        "default": "./dist/events.js"
      },
      "require": {
        "types": "./dist/events.d.cts",
        "default": "./dist/events.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "postbuild": "node scripts/fix-dts.mjs",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneIdentity/safeguard.js.git"
  },
  "keywords": [
    "One Identity",
    "Safeguard",
    "Privileged",
    "Passwords",
    "TypeScript",
    "SDK"
  ],
  "author": "Safeguard DevOps <safeguard-devops@groups.quest.com> (https://www.oneidentity.com/products/one-identity-safeguard-for-privileged-passwords/)",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/OneIdentity/safeguard.js/issues"
  },
  "homepage": "https://github.com/OneIdentity/safeguard.js#readme",
  "dependencies": {
    "undici": "^8.3.0"
  },
  "peerDependencies": {
    "@microsoft/signalr": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@microsoft/signalr": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@microsoft/signalr": "^10.0.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
